{
    "rewrites": [
        {
            "source": "/nodriza/assets/(.*)",
            "destination": "/assets/$1"
        },
        {
            "source": "/nodriza/(.*\\.(mp4|webp|jpeg|jpg|png|svg|ico|gif|woff|woff2|ttf))",
            "destination": "/$1"
        },
        {
            "source": "/nodriza/(.*)",
            "destination": "/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}